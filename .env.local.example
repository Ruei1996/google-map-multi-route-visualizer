# ─────────────────────────────────────────────────────────────────
# Google Maps Route Calculator — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────

# Google Maps Platform API Key (server-side only, never exposed to browser)
# Required APIs to enable in Google Cloud Console:
#   - Directions API
#   - Geocoding API
# https://console.cloud.google.com/apis/library
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# API quota limit (default: 40,000 ≈ $200 free credit at $5/1,000 requests)
MAPS_QUOTA_LIMIT=40000

# Optional: protect the /api/maps/quota/reset endpoint with a secret token
# QUOTA_RESET_TOKEN=your_secret_token_here

# Supabase (Cloud quota storage — recommended for production)
# When set, API call counts are persisted in Supabase and survive restarts.
# Without these, the app falls back to in-memory tracking (lost on restart).
#
# To set up:
#   1. Create a free project at https://supabase.com
#   2. Run supabase/migrations/001_api_quota.sql in the SQL editor
#   3. Copy the URL and keys from Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
